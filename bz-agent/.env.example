# ============================================================
#  BZ-Agent configuration  — copy this file to ".env"
# ============================================================

# --- Which LLM backend to use:  "bedrock"  or  "anthropic" ---
LLM_PROVIDER=bedrock

# --- If LLM_PROVIDER=bedrock (recommended, uses your AWS account) ---
AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# NOTE: enable "Anthropic Claude" in  Bedrock console > Model access  first.

# --- If LLM_PROVIDER=anthropic (needs a SEPARATE console.anthropic.com key) ---
# Your Claude Pro subscription does NOT provide this. Leave blank if using Bedrock.
ANTHROPIC_API_KEY=

# --- DynamoDB ---
DDB_TABLE_NAME=bz-agent-state
DDB_ENDPOINT_URL=             # set to http://localhost:8000 for local DynamoDB; blank = real AWS

# --- Open Data Hub (NOI Techpark) ---
# These are public, no key needed for most endpoints.
ODH_CONTENT_BASE=https://tourism.opendatahub.com
ODH_MOBILITY_BASE=https://mobility.api.opendatahub.com

# Bolzano centre, used as a default "near me" anchor
DEFAULT_LAT=46.4983
DEFAULT_LON=11.3548
